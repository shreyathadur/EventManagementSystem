# ============================================
# University Event Management System
# Environment Configuration
# ============================================

# Database Configuration (Neon Free or local)
# Use DATABASE_URL for Neon single connection string
DATABASE_URL=postgresql://user:password@hostname:5432/db_name?sslmode=require
# Or individual vars for local/Docker
DB_HOST=localhost
DB_PORT=5433
DB_NAME=university_ems
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_needs_to_be_at_least_32_characters_long
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# Stripe Payment (optional - uses mock mode if not set)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid Email (optional - logs to console if not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@university.edu

# AWS S3 (optional - uses local storage if not set)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# Cloudinary (optional fallback for images)
CLOUDINARY_URL=

# Google Maps API Key (optional)
GOOGLE_MAPS_API_KEY=

# Redis (optional - uses in-memory cache if not set)
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Sentry Error Tracking (optional)
SENTRY_DSN=
